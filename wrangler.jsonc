{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dealsrky-bridge",
  "compatibility_date": "2025-04-04",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "main": "./workers/app.ts",
  "observability": { "enabled": true },
  "triggers": {
    "crons": ["0 * * * *"]
  },

  // D1 Database
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dealsrky-db",
      "database_id": "a4f5fc8a-dddb-4a9b-8cbb-eaaaa05e793a"
    }
  ],

  // KV Cache
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "bc7a677541964c47964f2bfefb50e319"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BLOG_IMAGES",
      "bucket_name": "dealsrky-blog-images"
    }
  ],
  "ai": {
    "binding": "AI"
  },

  // Environment Variables
  "vars": {
    "ENVIRONMENT": "production",
    "SUPPORTED_MARKETPLACES": "US,CA,UK,DE,IT,FR,ES",
    "PUBLIC_APP_URL": "https://dealsrky.com",
    "DEFAULT_AMAZON_TAG": "rky3001-20",
    "DEFAULT_AMAZON_TAG_US": "rky3001-20",
    "DEFAULT_AMAZON_TAG_CA": "rky3002-20",
    "DEFAULT_AMAZON_TAG_UK": "rky3003-21",
    "DEFAULT_AMAZON_TAG_DE": "rky3007-21",
    "DEFAULT_AMAZON_TAG_FR": "rky3006-21",
    "DEFAULT_AMAZON_TAG_ES": "rky3004-21",
    "DEFAULT_AMAZON_TAG_IT": "rky3005-21",
    "BLOG_IMAGES_PUBLIC_BASE_URL": "",
    "BLOG_AI_PRIMARY_MODEL": "",
    "BLOG_AI_NEURON_DAILY_LIMIT": "10000",
    "OLLAMA_CLOUD_BASE_URL": "https://api.ollama.com",
    "OLLAMA_CLOUD_MODEL": "minimax-m2.7:cloud",
    "TELEGRAM_BOT_TOKEN": "",
    "TELEGRAM_WEBHOOK_SECRET": ""
  },

  // Secrets (set via `wrangler secret put`):
  // - JWT_SECRET
  // - AMAZON_API_KEY (optional)
  // - AMAZON_API_KEY_FALLBACK (optional)
  // - OLLAMA_CLOUD_BASE_URL (optional fallback)
  // - OLLAMA_CLOUD_API_KEY (optional fallback)
  // - OLLAMA_CLOUD_MODEL (optional fallback)
  // - TELEGRAM_BOT_TOKEN
  // - TELEGRAM_WEBHOOK_SECRET
}
